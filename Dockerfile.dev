# Dev image: run npm run dev with hot reload
FROM node:22-alpine

WORKDIR /app

# Install dependencies (copied so we can mount source over and still have node_modules in container if needed)
COPY package.json package-lock.json* ./
RUN npm ci 2>/dev/null || npm install

# Default: run dev server (source mounted at runtime)
EXPOSE 3000
CMD ["npm", "run", "dev"]
